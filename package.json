{
  "name": "chat-ia-api-free",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"bun run dev:back\" \"bun run dev:front\"",
    "dev:back": "bun run --cwd backend dev",
    "dev:front": "pnpm --prefix frontend dev",
    "install:all": "bun install && cd frontend && pnpm install",
    "build:all": "bun run --cwd backend build && pnpm --prefix frontend build"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
